{
  "name": "da-big-bren-bingo",
  "version": "1.0.0",
  "description": "A bingo board for Bren so he doesn't have to shit the bed in MS Paint",
  "keywords": [
    "twitch",
    "valorant",
    "bren",
    "emmy-winner"
  ],
  "license": "ISC",
  "author": "Squidward Tortellini",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "lint:client": "npm run lint --workspace=client",
    "lint:server": "npm run lint --workspace=server",
    "lint": "npm run lint:client && npm run lint:server",
    "build:client": "npm run build --workspace=client",
    "build": "npm run build:client",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "npm run dev:server & npm run dev:client"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7"
  }
}
